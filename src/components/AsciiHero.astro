---
---

<div class="hero-container" id="ascii-container">
  <!-- Three.js will inject the ASCII canvas here -->
  <button id="view-toggle" class="toggle-btn">VIEW: ASCII</button>
</div>

<style>
  .hero-container {
    width: 100%;
    height: 100%;
    overflow: hidden;
    background-color: #000;
    position: relative;
  }

  .toggle-btn {
    position: absolute;
    bottom: 20px;
    right: 20px;
    background: transparent;
    color: var(--accent-color, #00ff00);
    border: 1px solid var(--accent-color, #00ff00);
    padding: 8px 16px;
    font-family: 'Courier New', Courier, monospace;
    font-size: 12px;
    cursor: pointer;
    z-index: 100;
    transition: all 0.2s ease;
    text-transform: uppercase;
  }

  .toggle-btn:hover {
    background: var(--accent-color, #00ff00);
    color: #000;
  }

  /* AsciiEffect outputs a <pre> element */
  :global(.hero-container pre) {
    margin: 0 !important;
    padding: 0 !important;
    line-height: 1 !important;
    font-family: 'Courier New', Courier, monospace !important;
    font-size: 8px !important;
    font-weight: bold;
    background-color: #000 !important;
    color: #fff !important;
    pointer-events: none;
    width: 100% !important;
    height: 100% !important;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    position: absolute;
    top: 0;
    left: 0;
  }

  /* The raw WebGL canvas */
  :global(.hero-container canvas) {
    position: absolute;
    top: 0;
    left: 0;
    width: 100% !important;
    height: 100% !important;
  }
</style>

<script>
  import * as THREE from 'three';
  import { AsciiEffect } from 'three/examples/jsm/effects/AsciiEffect.js';

  let scene: THREE.Scene, camera: THREE.PerspectiveCamera, renderer: THREE.WebGLRenderer, effect: AsciiEffect;
  let knot: THREE.Mesh;
  let isAscii = true;

  const container = document.getElementById('ascii-container');
  const toggleBtn = document.getElementById('view-toggle');

  if (container) {
    init();
    animate();
  }

  function init() {
    // Scene
    scene = new THREE.Scene();

    // Camera
    camera = new THREE.PerspectiveCamera(70, window.innerWidth / window.innerHeight, 1, 1000);
    camera.position.set(0, 0, 500);
    camera.lookAt(0, 0, 0);

    // Lights
    const pointLight1 = new THREE.PointLight(0xffffff, 3, 0, 0);
    pointLight1.position.set(500, 500, 500);
    scene.add(pointLight1);

    const pointLight2 = new THREE.PointLight(0xffffff, 1, 0, 0);
    pointLight2.position.set(-500, -500, -500);
    scene.add(pointLight2);

    // Object
    const geometry = new THREE.TorusKnotGeometry(150, 40, 128, 32);
    const material = new THREE.MeshPhongMaterial({ flatShading: true });
    knot = new THREE.Mesh(geometry, material);
    scene.add(knot);

    // Renderer
    renderer = new THREE.WebGLRenderer({ antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);

    // Ascii Effect
    // Using user requested characters 'disk'
    const charSet = ' disk '; 
    effect = new AsciiEffect(renderer, charSet, { invert: true });
    effect.setSize(window.innerWidth, window.innerHeight);
    
    if (effect.domElement instanceof HTMLElement) {
      effect.domElement.style.color = 'white';
      effect.domElement.style.backgroundColor = 'black';
    }

    // Add both elements to the container
    container?.appendChild(renderer.domElement);
    container?.appendChild(effect.domElement);

    // Initial visibility
    updateView();

    if (toggleBtn) {
      toggleBtn.addEventListener('click', () => {
        isAscii = !isAscii;
        updateView();
      });
    }

    window.addEventListener('resize', onWindowResize);
  }

  function updateView() {
    if (effect.domElement instanceof HTMLElement) {
      effect.domElement.style.display = isAscii ? 'flex' : 'none';
    }
    renderer.domElement.style.display = isAscii ? 'none' : 'block';
    
    if (toggleBtn) {
      toggleBtn.innerText = `VIEW: ${isAscii ? 'ASCII' : '3D'}`;
    }
  }

  function onWindowResize() {
    const width = window.innerWidth;
    const height = window.innerHeight;

    camera.aspect = width / height;
    camera.updateProjectionMatrix();

    renderer.setSize(width, height);
    effect.setSize(width, height);
  }

  function animate() {
    requestAnimationFrame(animate);

    const timer = Date.now() * 0.0005;
    knot.rotation.x = timer * 0.5;
    knot.rotation.y = timer * 0.2;
    knot.rotation.z = timer * 0.3;

    if (isAscii) {
      effect.render(scene, camera);
    } else {
      renderer.render(scene, camera);
    }
  }
</script>
